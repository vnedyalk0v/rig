#!/bin/bash

set -u

resolve_rig_root() {
  local source_path source_dir target_path
  source_path=$1
  while [ -L "$source_path" ]; do
    source_dir=$(CDPATH='' cd -P -- "$(dirname -- "$source_path")" && pwd)
    target_path=$(readlink "$source_path")
    case "$target_path" in
      /*)
        source_path=$target_path
        ;;
      *)
        source_path=$source_dir/$target_path
        ;;
    esac
  done
  CDPATH='' cd -P -- "$(dirname -- "$source_path")" && pwd
}

RIG_ROOT=$(resolve_rig_root "$0")

. "$RIG_ROOT/lib/rig/common.sh"
. "$RIG_ROOT/lib/rig/catalog.sh"
. "$RIG_ROOT/lib/rig/config.sh"
. "$RIG_ROOT/lib/rig/shell.sh"
. "$RIG_ROOT/lib/rig/brew.sh"
. "$RIG_ROOT/lib/rig/apply.sh"
. "$RIG_ROOT/lib/rig/plan.sh"
. "$RIG_ROOT/lib/rig/prompts.sh"
. "$RIG_ROOT/lib/rig/doctor.sh"

rig_install_command() {
  if rig_args_include --help "$@" || rig_args_include -h "$@"; then
    rig_run_install "$@"
    return $?
  fi

  if ! rig_args_include --dry-run "$@"; then
    rig_require_macos || return 1
  fi

  rig_run_install "$@"
}

rig_self_update() {
  local update_branch

  rig_handle_command_help self-update \
    'Usage: rig self-update' \
    'Updates the local rig git clone with a fast-forward-only pull.' \
    "$@" || return $?
  if [ "$#" -gt 0 ]; then
    return 0
  fi

  rig_require_macos || return 1
  if [ ! -d "$RIG_ROOT/.git" ]; then
    rig_print_error "self-update requires a git clone; current rig root is $RIG_ROOT"
    return 1
  fi
  if ! rig_command_exists git; then
    rig_print_error "git is required for self-update"
    return 1
  fi
  rig_validate_clone_origin "$RIG_ROOT" || return 1
  if ! update_branch=$(git -C "$RIG_ROOT" symbolic-ref --quiet --short HEAD 2>/dev/null); then
    rig_print_error "self-update requires a checked-out branch; current rig clone is detached"
    return 1
  fi
  if ! rig_validate_branch_name "$update_branch"; then
    rig_print_error "invalid current rig branch name: $update_branch"
    return 1
  fi

  (
    cd "$RIG_ROOT" || exit 1
    git fetch origin "$update_branch" || exit 1
    git pull --ff-only origin "$update_branch" || exit 1
  )
}

rig_update_tools_command() {
  rig_handle_command_help update-tools \
    'Usage: rig update-tools' \
    'Updates installed workstation packages through Homebrew.' \
    "$@" || return $?
  if [ "$#" -gt 0 ]; then
    return 0
  fi
  rig_update_tools
}

rig_main() {
  local command_name

  if [ "$#" -eq 0 ]; then
    rig_usage
    return 0
  fi

  command_name=$1
  shift

  case "$command_name" in
    install)
      rig_install_command "$@"
      ;;
    dry-run)
      rig_render_dry_run "$@"
      ;;
    list)
      rig_print_list "$@"
      ;;
    doctor)
      rig_doctor "$@"
      ;;
    self-update)
      rig_self_update "$@"
      ;;
    update-tools)
      rig_update_tools_command "$@"
      ;;
    version|--version)
      printf 'rig %s\n' "$RIG_VERSION"
      ;;
    help|--help|-h)
      rig_usage
      ;;
    *)
      rig_print_error "unknown command: $command_name"
      rig_usage >&2
      return 1
      ;;
  esac
}

rig_main "$@"
